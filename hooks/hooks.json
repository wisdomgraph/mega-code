{
  "description": "MEGA-Code hooks for session collection and skill generation",
  "hooks": {
    "SessionStart": [{
      "hooks": [{
        "type": "command",
        "command": "bash \"${CLAUDE_PLUGIN_ROOT:-${extensionPath}}/scripts/session-start.sh\" \"${CLAUDE_PLUGIN_ROOT:-${extensionPath}}\"",
        "timeout": 30
      }]
    }],
    "SessionEnd": [{
      "hooks": [{
        "type": "command",
        "command": "MEGA_DIR=\"${CLAUDE_PLUGIN_ROOT:-${extensionPath}}\" && UV_CACHE_DIR=\"${UV_CACHE_DIR:-$MEGA_DIR/.uv-cache}\" uv run --directory \"$MEGA_DIR\" python mega_code/client/collector.py --event SessionEnd",
        "timeout": 30
      }]
    }],
    "UserPromptSubmit": [
      {
        "hooks": [{
          "type": "command",
          "command": "MEGA_DIR=\"${CLAUDE_PLUGIN_ROOT:-${extensionPath}}\" && UV_CACHE_DIR=\"${UV_CACHE_DIR:-$MEGA_DIR/.uv-cache}\" uv run --directory \"$MEGA_DIR\" python mega_code/client/collector.py --event UserPromptSubmit",
          "timeout": 5
        }]
      },
      {
        "hooks": [{
          "type": "command",
          "command": "MEGA_DIR=\"${CLAUDE_PLUGIN_ROOT:-${extensionPath}}\" && UV_CACHE_DIR=\"${UV_CACHE_DIR:-$MEGA_DIR/.uv-cache}\" uv run --directory \"$MEGA_DIR\" python mega_code/client/check_pending.py",
          "timeout": 5,
          "statusMessage": "Checking for pending skills..."
        }]
      }
    ],
    "Stop": [{
      "hooks": [{
        "type": "command",
        "command": "MEGA_DIR=\"${CLAUDE_PLUGIN_ROOT:-${extensionPath}}\" && UV_CACHE_DIR=\"${UV_CACHE_DIR:-$MEGA_DIR/.uv-cache}\" uv run --directory \"$MEGA_DIR\" python mega_code/client/collector.py --event Stop",
        "timeout": 5
      }]
    }]
  }
}
